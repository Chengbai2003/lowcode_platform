{
  "plugins": ["react", "typescript", "react-perf"],
  "categories": {
    "correctness": "warn"
  },
  "rules": {
    "typescript/no-explicit-any": "warn",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "react-hooks/exhaustive-deps": "warn"
  },
  "settings": {
    "react": {
      "pragma": "React"
    }
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "*.config.*",
    "packages/server/dist/**",
    "coverage/**"
  ]
}
