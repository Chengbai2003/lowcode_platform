{
  "name": "lowcode-platform",
  "version": "1.0.0",
  "private": true,
  "description": "A low-code platform with JSON schema to code generation",
  "scripts": {
    "dev": "pnpm --filter @lowcode-platform/frontend dev",
    "dev:backend": "pnpm --filter @lowcode-platform/backend dev",
    "build": "pnpm build:packages",
    "build:backend": "pnpm --filter @lowcode-platform/backend build",
    "build:packages": "pnpm --filter @lowcode-platform/frontend build",
    "clean": "pnpm -r clean",
    "type-check": "pnpm -r type-check",
    "lint": "oxlint packages/",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "lowcode",
    "low-code",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "oxlint": "^1.55.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@lowcode-platform/frontend": "workspace:*",
    "@reduxjs/toolkit": "^2.11.2",
    "react-redux": "^9.2.0"
  }
}
