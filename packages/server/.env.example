# ============================================
# 低代码平台后端服务环境配置
# 复制此文件为 .env 并填写实际值
# ============================================

# ============================================
# 应用基础配置
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
APP_NAME=Lowcode Platform Server
APP_VERSION=1.0.0

# ============================================
# CORS 配置
# ============================================
CORS_ENABLED=true
CORS_ORIGIN=*

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# ============================================
# JWT 配置（预留）
# ============================================
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=1d

# ============================================
# AI Provider 默认配置
# ============================================
AI_DEFAULT_PROVIDER=openai
AI_TIMEOUT=60000
AI_MAX_RETRIES=3
AI_ENABLE_STREAMING=true

# ============================================
# OpenAI 配置
# 支持 OpenAI 官方 API 及兼容服务
# ============================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OPENAI_MODEL=glm-4.7
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# ============================================
# Anthropic (Claude) 配置
# ============================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4096

# ============================================
# Ollama (本地模型) 配置
# 需要本地运行 Ollama 服务
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096

# ============================================
# LM Studio 配置
# 需要本地运行 LM Studio 并开启 API 服务
# ============================================
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_TEMPERATURE=0.7
LMSTUDIO_MAX_TOKENS=4096

# ============================================
# 自定义 OpenAI 兼容服务配置
# 支持 SiliconFlow, DeepSeek, Azure, OneAPI 等
# 格式：CUSTOM_PROVIDER_{N}_{FIELD}
# ============================================

# 示例：配置 SiliconFlow
# CUSTOM_PROVIDER_1_NAME=siliconflow
# CUSTOM_PROVIDER_1_API_KEY=your-siliconflow-api-key
# CUSTOM_PROVIDER_1_BASE_URL=https://api.siliconflow.cn/v1
# CUSTOM_PROVIDER_1_MODEL=deepseek-ai/DeepSeek-V2.5
# CUSTOM_PROVIDER_1_TEMPERATURE=0.7
# CUSTOM_PROVIDER_1_MAX_TOKENS=4096

# 示例：配置 DeepSeek
# CUSTOM_PROVIDER_2_NAME=deepseek
# CUSTOM_PROVIDER_2_API_KEY=your-deepseek-api-key
# CUSTOM_PROVIDER_2_BASE_URL=https://api.deepseek.com/v1
# CUSTOM_PROVIDER_2_MODEL=deepseek-chat
# CUSTOM_PROVIDER_2_TEMPERATURE=0.7
# CUSTOM_PROVIDER_2_MAX_TOKENS=4096

# ============================================
# 代码生成专用配置
# ============================================
CODEGEN_SYSTEM_PROMPT=
CODEGEN_MAX_TOKENS=8192
CODEGEN_TEMPERATURE=0.2

# ============================================
# 数据库配置（预留）
# ============================================
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=lowcode_platform
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# Redis 配置（预留）
# ============================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
